#!/usr/bin/env sh

# git pull / merge 完成后，仅在 Skill 目录发生变化时同步用户级 Skills。
repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
before="$(git rev-parse ORIG_HEAD 2>/dev/null || true)"
after="$(git rev-parse HEAD 2>/dev/null || true)"

node "$repo_root/scripts/ai-config.js" hooks sync-skills "$before" "$after" || {
  printf '%s\n' '[ai-repository] Skill 自动同步失败，请手动执行 ai-config.js 的 skills 命令' >&2
}

exit 0
