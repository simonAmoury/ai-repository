{
  "mcpServers": {
    "mysql": {
      "command": "uvx",
      "args": [
        "--from",
        "mysql-mcp-server",
        "mysql_mcp_server"
      ],
      "env": {
        "MYSQL_HOST": "172.24.2.34",
        "MYSQL_PORT": "3306",
        "MYSQL_USER": "mobi",
        "MYSQL_PASSWORD": "<your-password>"
      },
      "disabled": false,
      "autoApprove": [
        "query",
        "execute_sql"
      ],
      "disabledTools": []
    },
    "codegraph": {
      "type": "stdio",
      "command": "codegraph",
      "args": [
        "serve",
        "--mcp"
      ]
    }
  }
}
